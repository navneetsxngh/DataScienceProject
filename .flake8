[flake8]
max-line-length = 120
exclude =
    .venv,
    .git,
    __pycache__,
    build,
    dist,
    *.egg-info
per-file-ignores =
    # __init__.py files re-export names — unused imports are intentional
    __init__.py: F401, F811
ignore =
    # block comment style (## comments used throughout)
    E265,
    E266,
    # whitespace around keyword argument =
    E251,
    # missing blank lines before class/function (1 blank line used instead of 2)
    E302,
    E303,
    # trailing whitespace — handled by editor
    W291,
    W293,
    W292,
    # line break before binary operator
    W503
